# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GITHUB_TOKEN: Required for real APK compilation via Webhooks.
# Generate a Personal Access Token (classic) on GitHub with 'repo' and 'workflow' scopes.
GITHUB_TOKEN=""

# GITHUB_REPO: The GitHub repository to use as the build engine (e.g., "AbdullahSaeed/my-ide-builds")
GITHUB_REPO=""
